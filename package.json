{
  "name": "jeruguessr",
  "version": "2.4.1",
  "description": "JeruGuessr - A Jerusalem-themed GeoGuessr game.",
  "scripts": {
    "build": "node -e \"console.log('JeruGuessr: static site (no build output dir change)'); process.exit(0)\"",
    "dev": "npx wrangler pages dev .",
    "deploy": "npx wrangler pages deploy . --project-name jeruguessr --branch main --no-config",
    "start": "npx serve .",
    "test": "node tests/jg-utils.test.cjs && node scripts/verify-sw-assets.cjs",
    "test:mobile": "playwright test",
    "test:mobile:ui": "playwright test --ui"
  },
  "keywords": [
    "jerusalem",
    "geoguessr",
    "game",
    "leaflet",
    "cloudflare"
  ],
  "author": "Avraham Lipshitz",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
